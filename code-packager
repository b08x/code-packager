#!/bin/bash

# Version information
VERSION="0.3.1"

# Default values
INCLUDE_EXT=()     # Array to store include extensions
EXCLUDE_EXT=()     # Array to store exclude extensions
INCLUDE_FILES=()   # Array to store include filenames
EXCLUDE_FILES=()   # Array to store exclude filenames
MAX_SIZE=10240     # 10MB in KB
RESPECT_GITIGNORE=1  # Enable respecting files as per .gitignore by default
INCLUDE_DOT_FILES=0  # Exclude dot files and folders by default
DIRECTORY_PATH=""    # Initialize directory path as empty
OUTPUT_FILE=""       # Initialize output file path as empty
ZIP_OUTPUT=0         # Disable zipping the output file by default
USE_SELECTOR=""      # File/folder selector mode: tui, gui, or empty for manual
VECTOR_STORE_FORMAT=0  # Enable vector store optimized format
MAX_DEPTH=""         # Maximum search depth (unlimited by default)

# Function to display help
show_help() {
    echo "Usage: $0 -t <directory_path> -o <output_file> [options]"
    echo ""
    echo "Options:"
    echo ""
    echo "  -t <directory_path>     Target directory to process."
    echo "  -o <output_file>        Output file path."
    echo "  -i <include_extension>  Include files with the specified extension (with or without the leading dot)."
    echo "  -I <include_filename>   Include files with the specified filename."
    echo "  -e <exclude_extension>  Exclude files with the specified extension (with or without the leading dot)."
    echo "  -E <exclude_filename>   Exclude files with the specified filename."
    echo "  -s <max_size_in_kb>     Include files up to the specified size in kilobytes."
    echo "  -g <respect_gitignore>  0 to disable, 1 to enable respecting files as per .gitignore (default: enabled)."
    echo "  -d <include_dot_files>  0 to exclude, 1 to include dot files and folders (default: excluded)."
    echo "  -z <zip_output>         0 to disable, 1 to enable zipping the output file (default: disabled)."
    echo "  -m <max_depth>          Limit the maximum depth of the search (default: unlimited)."
    echo "  -S <selector_mode>      Use file/folder selector: 'tui' for fzf (with multi-select), 'gui' for yad (with checklist)."
    echo "  -V                      Enable vector store optimized format (embeds filename in content)."
    echo "  -v, --version           Display version information and exit."
    echo "  -h, --help              Display this help and exit."
    echo ""
    echo "Example:"
    echo ""
    echo "  $0 -t ~/project -o output.json -i .txt -i .md -I README -E LICENSE -s 500 -g 0 -d 1 -z 1"
    echo ""
    echo "  This command will search in '~/project' including only '.txt', '.md' files and 'README',"
    echo "  excluding 'LICENSE', considering files up to 500KB, not respecting files listed in .gitignore,"
    echo "  including dot files, and zipping the output file named 'output.json'."
    echo ""
    echo "Note: Information of binary files is included in the JSON output, but their contents are not stored."
}

# Function to display version
show_version() {
    echo "Code Packager for Language Models - Version $VERSION"
}

# Function to check if a file is binary
is_binary() {
    local file="$1"
    if [[ $(file --mime "$file" | grep -o 'charset=binary') ]]; then
        return 0 # It's a binary file
    else
        return 1 # It's not a binary file
    fi
}

# Check for required dependencies
check_dependencies() {
    local dependencies=("jq" "git" "file" "zip" "fd")
    local missing_deps=0
    for dep in "${dependencies[@]}"; do
        if ! command -v "$dep" &> /dev/null; then
            echo "Error: Required dependency '$dep' is not installed."
            missing_deps=1
        fi
    done
    
    # Check optional dependencies based on selector mode
    if [ "$USE_SELECTOR" = "tui" ] && ! command -v "fzf" &> /dev/null; then
        echo "Error: 'fzf' is required for TUI selector mode."
        missing_deps=1
    fi
    if [ "$USE_SELECTOR" = "gui" ] && ! command -v "yad" &> /dev/null; then
        echo "Error: 'yad' is required for GUI selector mode."
        missing_deps=1
    fi
    
    if [ "$missing_deps" -ne 0 ]; then
        echo "Please install the missing dependencies and try again."
        exit 1
    fi
}

# Function to use fzf for TUI file/folder selection
use_fzf_selector() {
    if [ -z "$DIRECTORY_PATH" ]; then
        DIRECTORY_PATH=$(find . -type d | fzf --prompt="Select directory: " --header="Choose target directory")
        if [ -z "$DIRECTORY_PATH" ]; then
            echo "No directory selected. Exiting."
            exit 1
        fi
    fi
    
    # Multi-select files and folders to include
    echo "Select files and folders to include (TAB to select multiple, ENTER to confirm):"
    selected_items=$(fd . "$DIRECTORY_PATH" | fzf --multi --prompt="Select items: " --header="TAB=select, ENTER=confirm, ESC=cancel" --preview="file {}" --preview-window=right:50%:wrap)
    
    if [ -z "$selected_items" ]; then
        echo "No items selected. Using all files in directory."
    else
        # Create a temporary file list
        temp_file_list=$(mktemp)
        echo "$selected_items" > "$temp_file_list"
        
        # Override the fd command to only process selected files
        SELECTED_FILES_LIST="$temp_file_list"
        export SELECTED_FILES_LIST
    fi
    
    if [ -z "$OUTPUT_FILE" ]; then
        OUTPUT_FILE=$(echo "" | fzf --print-query --prompt="Output file: " --header="Enter output JSON filename")
        if [ -z "$OUTPUT_FILE" ]; then
            OUTPUT_FILE="output.json"
        fi
        # Add .json extension if not present
        if [[ "$OUTPUT_FILE" != *.json ]]; then
            OUTPUT_FILE="${OUTPUT_FILE}.json"
        fi
    fi
}

# Function to use yad for GUI file/folder selection
use_yad_selector() {
    if [ -z "$DIRECTORY_PATH" ]; then
        DIRECTORY_PATH=$(yad --file-selection --directory --title="Select Directory to Package")
        if [ -z "$DIRECTORY_PATH" ]; then
            echo "No directory selected. Exiting."
            exit 1
        fi
    fi
    
    # Multi-select files and folders using yad checklist
    # First get the list of files using fd
    file_list=$(fd --type f . "$DIRECTORY_PATH")
    
    if [ -n "$file_list" ]; then
        # Create a temporary yad checklist
        yad_items=""
        while IFS= read -r file; do
            filename=$(basename "$file")
            yad_items+="FALSE|$file|$filename\n"
        done <<< "$file_list"
        
        # Show yad checklist for file selection
        selected_files=$(echo -e "$yad_items" | yad --list --checklist --title="Select Files to Include" \
            --text="Select files to include in the package:" \
            --column="Select" --column="Full Path" --column="Filename" \
            --width=800 --height=600 \
            --separator="|")
        
        if [ -n "$selected_files" ]; then
            # Create a temporary file list
            temp_file_list=$(mktemp)
            # Extract the selected file paths (second column)
            echo "$selected_files" | tr '|' '\n' | sed -n '2~3p' > "$temp_file_list"
            
            # Override the fd command to only process selected files
            SELECTED_FILES_LIST="$temp_file_list"
            export SELECTED_FILES_LIST
        else
            echo "No files selected. Using all files in directory."
        fi
    fi
    
    if [ -z "$OUTPUT_FILE" ]; then
        OUTPUT_FILE=$(yad --file-selection --save --title="Save JSON Output" --filename="output.json" --file-filter="JSON files | *.json" --file-filter="All files | *")
        if [ -z "$OUTPUT_FILE" ]; then
            echo "No output file selected. Exiting."
            exit 1
        fi
    fi
}

# Parse command line arguments
while getopts "t:o:i:I:e:E:s:g:d:z:m:S:Vvh-" opt; do
    case $opt in
        t) DIRECTORY_PATH="${OPTARG}" ;;
        o) OUTPUT_FILE="${OPTARG}" ;;
        i) INCLUDE_EXT+=("${OPTARG}") ;;
        I) INCLUDE_FILES+=("${OPTARG}") ;;
        e) EXCLUDE_EXT+=("${OPTARG}") ;;
        E) EXCLUDE_FILES+=("${OPTARG}") ;;
        s) MAX_SIZE="${OPTARG}"
            # Validate if MAX_SIZE is a valid number
            if ! [[ "$MAX_SIZE" =~ ^[0-9]+$ ]]; then
                echo "Error: Invalid value for -s option. Please provide a positive integer."
                exit 1
            fi
            ;;
        g) RESPECT_GITIGNORE="${OPTARG}" ;;
        d) INCLUDE_DOT_FILES="${OPTARG}" ;;
        z) ZIP_OUTPUT="${OPTARG}" ;;
        m) MAX_DEPTH="${OPTARG}" ;;
        S) USE_SELECTOR="${OPTARG}" ;;
        V) VECTOR_STORE_FORMAT=1 ;;
        v) show_version
           exit 0 ;;
        h) show_help
           exit 0 ;;
        -) case "${OPTARG}" in
             version) show_version
                      exit 0 ;;
             help) show_help
                  exit 0 ;;
             *) echo "Error: Invalid option -${OPTARG}. Use -h or --help for usage information." >&2
                exit 1 ;;
           esac ;;
    esac
done

# Use file/folder selectors if specified
case "$USE_SELECTOR" in
    "tui")
        use_fzf_selector
        ;;
    "gui")
        use_yad_selector
        ;;
    "")
        # No selector, continue with normal validation
        ;;
    *)
        echo "Error: Invalid selector mode '$USE_SELECTOR'. Use 'tui' for fzf or 'gui' for yad."
        exit 1
        ;;
esac

# Ensure required parameters are provided
if [ -z "$DIRECTORY_PATH" ]; then
    echo "Directory path is required."
    show_help
    exit 1
fi

# Check if directory exists
if [[ ! -d "$DIRECTORY_PATH" ]]; then
  echo "Error: Directory '$DIRECTORY_PATH' does not exist."
  exit 1
fi

# Determine the output file name if a directory is specified
if [ -d "$OUTPUT_FILE" ]; then
    base_dir=$(basename "$(realpath "$DIRECTORY_PATH")")
    OUTPUT_FILE="$OUTPUT_FILE/$base_dir.json"
fi

# Validate output file path
output_dir=$(dirname "$OUTPUT_FILE")
if [[ ! -d "$output_dir" || ! -w "$output_dir" ]]; then
  echo "Error: Cannot write to output directory '$output_dir'."
  exit 1
fi

# Check dependencies before proceeding
check_dependencies

# Normalize the include and exclude extensions to ensure they start with a dot
for i in "${!INCLUDE_EXT[@]}"; do
    if [[ "${INCLUDE_EXT[$i]}" != "" && "${INCLUDE_EXT[$i]:0:1}" != "." ]]; then
        INCLUDE_EXT[$i]=".${INCLUDE_EXT[$i]}"
    fi
done

for i in "${!EXCLUDE_EXT[@]}"; do
    if [[ "${EXCLUDE_EXT[$i]}" != "" && "${EXCLUDE_EXT[$i]:0:1}" != "." ]]; then
        EXCLUDE_EXT[$i]=".${EXCLUDE_EXT[$i]}"
    fi
done

# Determine OS and set the appropriate stat command
if [[ "$OSTYPE" == "darwin"* ]]; then
    STAT_CMD="stat -f%z"
else
    STAT_CMD="stat -c%s"
fi

# Function to process each file
process_file() {
    local file="$1"
    
    local filesize=$($STAT_CMD "$file")
    if [ "$filesize" -le $((MAX_SIZE * 1024)) ]; then
        local filename=$(basename "$file")
        local dirpath=$(dirname "$file" | sed "s|^$DIRECTORY_PATH||")
        local full_path="${dirpath}/${filename}"
        
        if is_binary "$file"; then
            if [ "$VECTOR_STORE_FORMAT" -eq 1 ]; then
                local content=$(jq -Rs . <<< "File: ${full_path}

[Binary file - content not included]")
            else
                local content="null" # Do not include content for binary files
            fi
        else
            local file_content=$(cat "$file")
            if [ "$VECTOR_STORE_FORMAT" -eq 1 ]; then
                local content=$(jq -Rs . <<< "File: ${full_path}

${file_content}")
            else
                local content=$(jq -Rs . < "$file")
            fi
        fi
        
        if [ "$VECTOR_STORE_FORMAT" -eq 1 ]; then
            echo "{\"content\":$content, \"metadata\":{\"filename\":\"$filename\", \"path\":\"$dirpath/\", \"full_path\":\"$full_path\"}}"
        else
            echo "{\"filename\":\"$filename\", \"content\":$content, \"path\":\"$dirpath/\"}"
        fi
    fi
}

export -f process_file is_binary
export STAT_CMD MAX_SIZE DIRECTORY_PATH VECTOR_STORE_FORMAT

# Construct the fd command
fd_command="fd"

# File type: only regular files
fd_command+=" --type f"

# Handle gitignore settings
if [ "$RESPECT_GITIGNORE" -eq 0 ]; then
    fd_command+=" --no-ignore-vcs"
fi

# Handle hidden files
if [ "$INCLUDE_DOT_FILES" -eq 1 ]; then
    fd_command+=" --hidden"
fi

# Handle max depth if set
if [ -n "$MAX_DEPTH" ]; then
    fd_command+=" --max-depth $MAX_DEPTH"
fi

# Add size filter - fd uses native size filtering
fd_command+=" --size -${MAX_SIZE}k"

# Handle extensions - fd has native support
for ext in "${INCLUDE_EXT[@]}"; do
    # Remove leading dot if present since fd -e expects extension without dot
    clean_ext="${ext#.}"
    fd_command+=" -e $clean_ext"
done

# Handle exclusions
for ext in "${EXCLUDE_EXT[@]}"; do
    fd_command+=" --exclude '*$ext'"
done

for filename in "${EXCLUDE_FILES[@]}"; do
    fd_command+=" --exclude '$filename'"
done

# For include filenames, we need to use a pattern
# If we have specific filenames to include and no extensions, use pattern matching
if [ ${#INCLUDE_FILES[@]} -gt 0 ] && [ ${#INCLUDE_EXT[@]} -eq 0 ]; then
    # Build pattern for specific filenames
    if [ ${#INCLUDE_FILES[@]} -eq 1 ]; then
        fd_command+=" '^${INCLUDE_FILES[0]}$'"
    else
        # Multiple filenames - create regex pattern
        pattern="^("
        for i in "${!INCLUDE_FILES[@]}"; do
            if [ $i -gt 0 ]; then
                pattern+="|"
            fi
            pattern+="${INCLUDE_FILES[$i]}"
        done
        pattern+=")$"
        fd_command+=" '$pattern'"
    fi
elif [ ${#INCLUDE_FILES[@]} -gt 0 ]; then
    # We have both extensions and filenames - need to handle this with multiple fd calls
    # For now, we'll warn and use extensions only
    echo "Warning: Both extensions and specific filenames specified. Using extensions only."
    echo "Specific filenames will be ignored: ${INCLUDE_FILES[*]}"
fi

# Add search path - fd syntax is: fd [options] [pattern] [path]
if [ ${#INCLUDE_FILES[@]} -gt 0 ] && [ ${#INCLUDE_EXT[@]} -eq 0 ]; then
    # Pattern was already added for filename matching, just add path
    fd_command+=" '$DIRECTORY_PATH'"
else
    # No specific filename pattern - use match-all pattern
    fd_command+=" . '$DIRECTORY_PATH'"
fi

# Debug: show the fd command being executed
# echo "Debug: $fd_command"

# Execute fd command and process files
if [ -n "$SELECTED_FILES_LIST" ] && [ -f "$SELECTED_FILES_LIST" ]; then
    # Use the manually selected files from fzf multi-select
    echo "Processing manually selected files..."
    fd_result=$(cat "$SELECTED_FILES_LIST")
    # Clean up temporary file
    rm -f "$SELECTED_FILES_LIST"
else
    # Use normal fd command
    fd_result=$(eval "$fd_command")
    if [[ $? -ne 0 ]]; then
      echo "Error: fd command failed with error:"
      echo "$fd_result"
      exit 1
    fi
fi
json_array=$(echo "$fd_result" | xargs -I {} bash -c 'process_file "{}"' | jq -s .)

# Output the JSON object using jq and pretty print
echo "{\"files\":$json_array}" | jq . > "$OUTPUT_FILE"

# Zip the output file if requested
if [ "$ZIP_OUTPUT" -eq 1 ]; then
    zip_file="${OUTPUT_FILE%.*}.zip"
    zip -jq "$zip_file" "$OUTPUT_FILE"
    # Check zip exit status
    if [[ $? -ne 0 ]]; then
        echo "Error: Failed to zip the output file."
        exit 1
    fi
    echo "Output file zipped: $zip_file"
fi

echo "JSON output saved to: $OUTPUT_FILE"

# Generate directory tree
echo "Directory tree:"
if [ -n "$fd_result" ]; then
    echo "$fd_result"
else
    eval "$fd_command"
fi
